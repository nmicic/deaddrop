# deaddrop deployment secrets — copy to .env and fill in real values.
# Generate with:
#   DEADDROP_DEPLOY_SECRET=hex:$(openssl rand -hex 32)
#   DEADDROP_WRITE_TOKEN=hex:$(openssl rand -hex 32)
#   CADDY_PREFIX=$(openssl rand -hex 16)
#   SITE_ADDR=deaddrop.example.com

DEADDROP_DEPLOY_SECRET=hex:CHANGE_ME
DEADDROP_WRITE_TOKEN=hex:CHANGE_ME
CADDY_PREFIX=CHANGE_ME
SITE_ADDR=deaddrop.example.com
